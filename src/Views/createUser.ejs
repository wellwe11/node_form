<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>

  <body>
    <h1><%= title %></h1>

    <form
      action="/create
    "
      method="POST"
    >
      <label for="firstName">First Name: </label>
      <input
        type="text"
        name="firstName"
        id="firstName"
        required
        placeholder="name..."
      />

      <label for="LastName">Last Name: </label>
      <input
        type="text"
        name="lastName"
        id="lastName"
        required
        placeholder="last name..."
      />
    </form>

    <a href="/">Back to home</a>
  </body>
</html>
