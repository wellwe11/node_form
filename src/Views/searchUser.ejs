<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= title %></title>
  </head>

  <body>
    <h1><%= title %></h1>
    <%- include("partials/errors.ejs") %>

    <form action="/search/results" method="GET">
      <p><i>Please fill out either Name or Email</i></p>

      <label for="email">Search by email</label>
      <input type="email" name="email" id="searchEmail" />

      <label for="name">Search by name</label>
      <input type="text" name="name" id="searchName" />

      <button type="submit">Search</button>
    </form>


    <% if (user) { %>
        <div>

            <form action="/<%= user.id %>/delete" method="POST" style="display:inline;">
                <button type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
            </form>
            <p><%= user.firstName %></p>
            <p><%= user.lastName %></p>
            <p><%= user.email %></p>
            <a href="/<%= user.id %>/update">Update</a>
        </div>

            <% } %>

          

    <a href="/">Back to home</a>
  </body>
</html>
